APP_NAME="Rekam Medis Elektronik"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database MySQL ───────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rme_db
DB_USERNAME=rme_user
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ─── Redis Queue ──────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Redis Queue database index
REDIS_QUEUE_DB=1

# ─── Redis Cache ──────────────────────────────────────────────────────────────
CACHE_DRIVER=redis
CACHE_PREFIX=rme_cache
REDIS_CACHE_DB=2

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=30
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Broadcasting / Laravel Reverb ────────────────────────────────────────────
BROADCAST_DRIVER=reverb

REVERB_APP_ID=rme-app
REVERB_APP_KEY=rme-app-key
REVERB_APP_SECRET=rme-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@rme.local"
MAIL_FROM_NAME="${APP_NAME}"

# ─── File Storage ─────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── BPJS VClaim Integration ──────────────────────────────────────────────────
BPJS_MODE=testing
BPJS_ENDPOINT_URL=https://apijkn.bpjs-kesehatan.go.id/vclaim-rest
BPJS_SANDBOX_URL=https://apijkn-dev.bpjs-kesehatan.go.id/vclaim-rest-dev
BPJS_CONSUMER_KEY=
BPJS_CONSUMER_SECRET=

# ─── SATUSEHAT (FHIR) Integration ────────────────────────────────────────────
SATUSEHAT_MODE=testing
SATUSEHAT_ENDPOINT_URL=https://api-satusehat.kemkes.go.id
SATUSEHAT_SANDBOX_URL=https://api-satusehat-stg.dto.kemkes.go.id
SATUSEHAT_CLIENT_ID=
SATUSEHAT_CLIENT_SECRET=

# ─── Aplicare Integration ─────────────────────────────────────────────────────
APLICARE_MODE=testing
APLICARE_ENDPOINT_URL=
APLICARE_SANDBOX_URL=
APLICARE_API_KEY=

# ─── Kemenkes Integration ─────────────────────────────────────────────────────
KEMENKES_MODE=testing
KEMENKES_ENDPOINT_URL=
KEMENKES_SANDBOX_URL=
KEMENKES_API_KEY=

# ─── INA-CBGs Integration ─────────────────────────────────────────────────────
INACBGS_MODE=testing
INACBGS_ENDPOINT_URL=
INACBGS_SANDBOX_URL=
INACBGS_USERNAME=
INACBGS_PASSWORD=

# ─── Notification Services ────────────────────────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
SMS_API_URL=
SMS_API_KEY=

# ─── Sanctum ──────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000
